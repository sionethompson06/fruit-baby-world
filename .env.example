# Fruit Baby World — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit real secrets to the repository.

# OpenAI API key for AI episode package generation (Phase 2E+)
# Required for /api/generate-episode-package to return generated content.
# Without this key the route returns a safe setup_required response.
OPENAI_API_KEY=

# GitHub credentials for saving approved episode drafts (Phase 3A+)
# Required for /api/github/save-episode to commit episode JSON files.
# Without these variables the route returns a safe setup_required response.
# Use a fine-grained personal access token with Contents: Read and Write
# permission scoped to this repository only.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=

# Admin passcode for Story Studio access (Phase 3G.1+)
# Required to access /admin pages and write-capable API routes.
# Choose a strong passcode and keep it secret.
ADMIN_PASSCODE=

# Vercel Blob token for approved story panel image uploads (Phase 6F+)
# Required for /api/media/upload-story-panel-image to store approved assets.
# Without this token the route returns a safe setup_required response.
# Create a Blob store in your Vercel project dashboard and copy the token.
BLOB_READ_WRITE_TOKEN=

# Video generation provider for future animation clip generation (Phase 7A+)
# Required for /api/generate-animation-clip to generate animated story clips.
# Without these variables the route returns a safe not_implemented_yet response.
# Supported providers (Phase 14B+): runway, luma, fal, replicate
VIDEO_GENERATION_PROVIDER=
VIDEO_GENERATION_API_KEY=
# VIDEO_GENERATION_MODEL_ID is optional — leave blank to use the provider's default model.
# Example values: gen4_turbo (Runway), dream-machine (Luma), fal-ai/kling-video (Fal)
VIDEO_GENERATION_MODEL_ID=

# Provider-specific API keys (Phase 14B+)
# These override VIDEO_GENERATION_API_KEY when the matching provider is active.
# Only one set is needed depending on VIDEO_GENERATION_PROVIDER.
RUNWAY_API_KEY=
LUMA_API_KEY=
FAL_KEY=
REPLICATE_API_TOKEN=

# ElevenLabs audio narration provider (Phase 13A+)
# ELEVENLABS_API_KEY is required for future narration generation (Phase 13B+).
# Without this key the narration setup section will show "Not Configured".
# No audio is generated in Phase 13A — this key is only checked for readiness status.
ELEVENLABS_API_KEY=

# ELEVENLABS_DEFAULT_VOICE_ID is optional but recommended.
# Set this to your preferred ElevenLabs voice ID for the default narration voice.
ELEVENLABS_DEFAULT_VOICE_ID=

# ELEVENLABS_MODEL_ID is optional — defaults to eleven_multilingual_v2 if not set.
# Example values: eleven_multilingual_v2, eleven_monolingual_v1, eleven_turbo_v2_5
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
