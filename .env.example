# Fruit Baby World — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit real secrets to the repository.

# OpenAI API key for AI episode package generation (Phase 2E+)
# Required for /api/generate-episode-package to return generated content.
# Without this key the route returns a safe setup_required response.
OPENAI_API_KEY=

# GitHub credentials for saving approved episode drafts (Phase 3A+)
# Required for /api/github/save-episode to commit episode JSON files.
# Without these variables the route returns a safe setup_required response.
# Use a fine-grained personal access token with Contents: Read and Write
# permission scoped to this repository only.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=

# Admin passcode for Story Studio access (Phase 3G.1+)
# Required to access /admin pages and write-capable API routes.
# Choose a strong passcode and keep it secret.
ADMIN_PASSCODE=

# Vercel Blob token for approved story panel image uploads (Phase 6F+)
# Required for /api/media/upload-story-panel-image to store approved assets.
# Without this token the route returns a safe setup_required response.
# Create a Blob store in your Vercel project dashboard and copy the token.
BLOB_READ_WRITE_TOKEN=
